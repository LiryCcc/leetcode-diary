{
  "type": "module",
  "scripts": {
    "check-format": "prettier --check --cache .",
    "format": "prettier --write --cache .",
    "lint": "pnpm check-format && pnpm lint-code && pnpm lint-style && pnpm lint-spell",
    "lint-code": "eslint --cache .",
    "lint-spell": "cspell .",
    "lint-style": "stylelint src/**/*.css",
    "prepare": "simple-git-hooks",
    "test": "vitest run --coverage",
    "tn": "ts-node"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint"
  },
  "dependencies": {
    "datastructures-js": "^13.0.0",
    "dayjs": "^1.11.19"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@types/node": "^24.10.4",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "4.0.16",
    "cspell": "^9.4.0",
    "eslint": "^9.39.2",
    "globals": "^16.5.0",
    "jiti": "^2.6.1",
    "prettier": "^3.7.4",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-packagejson": "^2.5.20",
    "radash": "^12.1.1",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard": "^39.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.0",
    "vite": "^7.3.0",
    "vitest": "^4.0.16"
  }
}
